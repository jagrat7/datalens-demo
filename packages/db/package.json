{
  "name": "@oneflow-demo/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:local": "turso dev --db-file local.db",
    "db:push": "bun node_modules/drizzle-kit/bin.cjs push",
    "db:generate": "bun node_modules/drizzle-kit/bin.cjs generate",
    "db:studio": "bun node_modules/drizzle-kit/bin.cjs studio",
    "db:migrate": "bun node_modules/drizzle-kit/bin.cjs migrate",
    "db:seed": "bun src/seed.ts"
  },
  "dependencies": {
    "@libsql/client": "0.17.4",
    "@oneflow-demo/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.2",
    "libsql": "0.5.29",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@oneflow-demo/config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "typescript": "catalog:"
  }
}
