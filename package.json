{
  "name": "oneflow-demo",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.4.2",
      "zod": "^4.4.3",
      "typescript": "^6",
      "@types/bun": "^1.3.14",
      "lucide-react": "^1.23.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.7",
      "react-dom": "^19.2.7",
      "sonner": "^2.0.7",
      "@types/react": "^19.2.17",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.3.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "nx run-many -t dev",
    "build": "nx run-many -t build",
    "check-types": "nx run-many -t check-types",
    "dev:web": "nx run-many -t dev --projects=web",
    "dev:server": "nx run-many -t dev --projects=server",
    "db:push": "bun run --cwd packages/db db:push",
    "db:studio": "bun run --cwd packages/db db:studio",
    "db:generate": "bun run --cwd packages/db db:generate",
    "db:migrate": "bun run --cwd packages/db db:migrate",
    "db:seed": "bun run --cwd packages/db db:seed",
    "db:local": "bun run --cwd packages/db db:local",
    "check": "oxlint && oxfmt --write"
  },
  "dependencies": {
    "@oneflow-demo/env": "workspace:*",
    "ai": "^7.0.35",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@oneflow-demo/config": "workspace:*",
    "@types/bun": "catalog:",
    "nx": "^23.0.1",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.14"
}
